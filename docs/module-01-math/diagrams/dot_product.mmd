graph LR
    subgraph Aligned
    A1[Vector A] --- B1[Vector B]
    A1 --> C1[High Positive Score]
    end
    subgraph Orthogonal
    A2[Vector A] --- B2[Vector B]
    A2 --> C2[Zero Score]
    end
    subgraph Opposite
    A3[Vector A] --- B3[Vector B]
    A3 --> C3[Negative Score]
    end
    style C1 fill:#dfd
    style C2 fill:#eee
    style C3 fill:#fdd
